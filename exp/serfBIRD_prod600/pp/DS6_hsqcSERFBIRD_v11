;SERFBIRD
;avance-version (12/01/11)
;HSQC
;2D H-1/X correlation via INEPT-ST2PT
;phase sensitive using Echo/Antiecho-TPPI gradient selection and Pell-Keeler method
;using trim pulses in inept transfer
;with water presat

; Davy Sinnaeve, CNRS, Lille, 2023
; Please cite: Cantrelle F.X., Boll E., Sinnaeve D. "Making 1H-1H couplings more accessible and accurate with selective 2DJ NMR experiments aided by 13C satellites"

; OPTIONS
;   set following entries in ZGOPTNS to enable the following options (preceded by -D)
;     push_RT  : real-time BIRD homodecoupling (2D experiment)
;     push_INT : interferogram homodecoupling (pseud03D experiment)
;     CALC_SPH : automatic calculation of 1H selective pulse lengths and power levels
;     SEL13C   : using selective 13C refocusing pulse for editing, with automatic calculation of pulse lengths and power level
;     CH2suppr : suppression of CH2 signals using difference spectroscopy

;   Do not use push_RT and push_INT together!

; CNST15 controls 13C chemical shift and 1H coupling sampling.
;   CNST15=0   : F1 is a pure 1H-1H J-dimension
;   0<CNST15<1 : co-sampling of 1H-1H J-coupling and 13C chemical shift, with the latter weigthed (downscaled) by cnst15
;   CNST15>=1  : co-sampling of 1H-1H J-coupling and 13C chemical shift, with the former weigthed (upscaled) by cnst15

; l2 controls which 13C spin-state is observed
;   l2 = 0 : beta spin-state (left-hand 13C satellite)
;   l2 = 1 : alpha spin-state (right-hand 13C satellite)

; Tested on Topspin 3.6.2
; for Avance NEO : 
;    comment out or remove the "dwellmode explicit" line
;    comment out or remove the lines containing "DWL_CLK_ON" or "DWL_CLK_OFF"
;    activate the lines containing "DWELL_RELEASE" or "DWELL_HOLD" by removing the semicolons


;$CLASS=HighRes
;$DIM=2D
;$TYPE=
;$SUBTYPE=
;$COMMENT=

#include <Avance.incl>
#include <Grad.incl>
#include <Delay.incl>
#include <De.incl>

define delay del_bird
define delay del_p39
define delay del_corr
define delay tauA
define delay tauB
define delay ChunkLength
define delay AQ_tot
 
"d11=30m"

"p2=p1*2"
"p4=p3*2"
"plw0=0"
"plw20=0"

"d3 = 1s/(cnst3*2)" ; used for BIRD
"d4=1s/(cnst2*4)"   ; used for INEPT

"d0=0"  ; hsqc 13C chemical shift evolution 
"d10=0" ; 2DJ HH J-coupling evolution 
"d30=0" ; interferogram 1H chemical shift evolution

#   ifdef push_INT  ; interferogram homodecoupling
"in0=min(cnst15,1.0)*inf2/2" ; 13C chemical shift evolution time increment ; downscaling the 13C chemical shift if cnst15<1
"in10=max(cnst15,1.0)*inf2/2" ; 2DJ dimension time increment ; upscaling the J(HH)-coupling if cnst15>1
"ChunkLength=dw*l31*2" ; chunk length
"AQ_tot=ChunkLength*td1" ; total acquisition time of reconstructed FID  
"cnst0=1/ChunkLength*(AQ_tot/AQ_tot)" ; SW associated with pure shift dimension for easy reference, ideally 2x multiplet width
"in30=ChunkLength/2" ; interferogram pure shift pseudo2D dimension time increment
"tauA=ChunkLength/(4*cnst0/cnst0)" ; "cnst0/cnst0" is to make cnst0 appear in acquisition parameter list
"tauB=dw*2*cnst4"
#   else
"in0=min(cnst15,1.0)*inf1/2" ; 13C chemical shift evolution time increment ; downscaling the 13C chemical shift if cnst15<1
"in10=max(cnst15,1.0)*inf1/2" ; 2DJ dimension time increment ; upscaling the J(HH)-coupling if cnst15>1
"tauA=0"
"tauB=0"
#   endif

"TAU=p16+d16+p2+d10*2"
"DELTA2=d4-p1*2/PI"        ; INEPT
"DELTA3=d4-cnst17*p24/2-4u"; ST2PT
"DELTA4=DELTA3-p1*2/PI"    ; ST2PT
"DELTA5=DELTA3-p3"         ; ST2PT

"del_bird=d3-larger(p2,p39)*0.5" ; delay used in BIRD

"del_p39=p39"
"del_corr = d16 - de"

#   ifdef SEL13C  ;selective 13C 180 refocusing pulse to select a 13C region.
"spoal1=0.5"
"cnst33=cnst28*bf2"  ; cnst28 = width in ppm of wanted 13C selected region (centered around o2)
"p15=1000000*bwfac1/(cnst33)" 
"cnst34 = (p15/(p3*2)) * (p15/(p3*2))"
"spw1 = plw2/(cnst34*integfac1*integfac1)"
"spoffs1 = 0"
#   endif

#   ifdef CALC_SPH ; power level and pulse length are automatically calculated for 1H selective pulses
"spoal11=0.5"
"spoal12=0.5"
"cnst11=(cnst7+cnst6)*0.5" ; cnst6/cnst7 = lower/higher chemical shift selected 1H region 
"cnst13=abs(cnst7-cnst6)*bf1"
"if ( cnst13 == 0 ) {cnst36 = 1000.0;} else {cnst36 = cnst13;}" ; set cnst36 to a safe 1000 Hz if cnst6 and cnst7 have the same values
"p11=1000000*bwfac11/cnst36"
"cnst37 = (p11/(p1*2)) * (p11/(p1*2))"
"spw11 = plw1/(cnst37*integfac11*integfac11)"
"spw12=spw11"
#   endif
;shape pulse selected spin
"cnst12 = cnst11*bf1"
"spoffs11 = cnst12 - o1" ; offset
"spoffs12=spoffs11"
 
#   ifdef CH2suppr ; for CH2 suppression difference spectroscopy
"d21=1s/(cnst5*2)"
"td0=2"
"ns=ns/2" 
"l5=0"
#   endif 

"l1 = 0" ; switch for Pell-Keeler

"acqt0=0"
baseopt_echo

#   ifdef push_RT ; for real-time homodecoupling (at least Avance III needed)
"d62=aq/l10"
"d63=d62/2"
"l11=l10/2-1"

dwellmode explicit
#   endif 

#   ifdef push_INT ; if interferogram homodecoupling
aqseq 312
#   endif 

1 ze
  d11
2 1m
  50u BLKGRAMP
  20u LOCKH_OFF
  4u pl9:f1
  d1 cw:f1 ph29
  4u do:f1
  4u pl1:f1
3 (p1 ph1)
  DELTA2 pl20:f2
  4u
  (center (p2 ph1) (p14:sp3 ph1):f2 )
  4u
  DELTA2 pl2:f2 UNBLKGRAD
  p28 ph1
  4u
  (p1 ph2) (p3 ph3):f2

  d0 

#   ifdef CH2suppr
  if "l5%2 == 1"     ; difference spectroscopy CH2 suppression
     {
     d21
     }
#   endif 

  (p2 ph25)

#   ifdef CH2suppr
  if "l5%2 == 0"     ; difference spectroscopy CH2 suppression
     {
     d21
     }
#   endif

  d0

  p16:gp1*EA
  d16

#   ifdef SEL13C
  (p15:sp1 ph4+ph8):f2
#   else
  (p24:sp7 ph4+ph8):f2
#   endif 

#   ifdef CH2suppr
  d21
#   endif

  TAU pl2:f2

  (p1 ph1)
  4u
  DELTA3 pl20:f2
  (center (p2 ph1) (p24:sp7 ph9:r):f2 )
  4u
  DELTA3 pl2:f2
  (ralign (p1 ph14+ph2) (p3 ph1):f2 )
  4u
  DELTA4 pl20:f2
  (center (p2 ph1) (p24:sp7 ph9:r):f2 )
  4u
  DELTA5 pl2:f2
  if "l2 == 0"     
     {
     (p3 ph15):f2
     }
  else
     {
     (p3 ph15+ph20):f2
     }

  4u pl20:f2
  (p39:sp4 ph1):f2
  4u

  20u

  tauB
  tauA 
  p16:gp3
  d16
  p2 ph5
  p16:gp4 
  d16
  tauA

  d30 ; interferogram pure shift

  if "l1 %2 == 1"     ; R-type
     {
     d10 ;JHH
     }  

  p16:gp7 
  d16
  2u pl0:f1
  2u
  p11:sp11:f1 ph11  ; sel. 180 pulse on spin S
  2u
  2u pl1:f1
  p16:gp7*-1
  d16

  if "l1 %2 == 0"     ; N-type 
     {
     d10 ;JHH evolution
     } 

  p16:gp5 
  d16
  4u
  (p39:sp4 ph1):f2
  4u
  (p1 ph6)
  del_bird
  (center (p2 ph16) (p39:sp4 ph1):f2 )    ; BIRD
  del_bird
  (p1 ph17)
  p16:gp5 
  d16 
  4u
  del_p39
  4u

  if "l1 %2 == 1"     ; R-type
     {
     d10 ;JHH
     }  

  p16:gp8 
  d16
  2upl0:f1
  2u
  p11:sp12:f1 ph12  ; sel. 180 pulse on spin S
  2u
  2u pl1:f1
  p16:gp8*-1
  d16

  if "l1 %2 == 0"     ; N-type 
     {
     d10 ;JHH evolution
     } 

  p16:gp6
  d16 
  p2 ph7
  p16:gp6 
  del_corr
  4u
  del_p39
  4u

  d30  ; interferogram pure shift
  
#   ifdef push_RT       ; if real-time homodecoupling

  20u

  ACQ_START(ph30,ph31)
  ;0.1u START_NEXT_SCAN
  0.1u REC_UNBLK
  ;0.05u DWELL_RELEASE
  0.05u DWL_CLK_ON
  d63
  ;0.05u DWELL_HOLD
  0.05u DWL_CLK_OFF
  0.1u REC_BLK
  
  p29:gp21
  d26 rpp10
  (p2 ph1+ph10)
  p29:gp21
  d26

	d60

  p29:gp22
  d26

  del_p39 pl20:f2
  (p1 ph1+ph10)
  del_bird
  (center (p2 ph2+ph10) (p39:sp4 ph10):f2 )
  del_bird
  (p1 ph20+ph10)
  (p39:sp4 ph20+ph10):f2

  p29:gp22
  d26
	d60  

4 0.1u REC_UNBLK
  ;0.05u DWELL_RELEASE
  0.05u DWL_CLK_ON
  d62
  ;0.05u DWELL_HOLD
  0.05u DWL_CLK_OFF
  0.1u REC_BLK

  p29:gp23
  d26 ipp10
  (p2 ph1+ph10)
  p29:gp23
  d26

	d60

  p29:gp24
  d26

  del_p39 pl20:f2
  (p1 ph1+ph10)
  del_bird
  (center (p2 ph2+ph10) (p39:sp4 ph10):f2 )
  del_bird
  (p1 ph20+ph10)
  (p39:sp4 ph20+ph10):f2

  p29:gp24
  d26
	d60  

  0.1u REC_UNBLK
  ;0.05u DWELL_RELEASE
  0.05u DWL_CLK_ON
  d62
  ;0.05u DWELL_HOLD
  0.05u DWL_CLK_OFF
  0.1u REC_BLK
  
  p29:gp21
  d26 ipp10
  (p2 ph1+ph10)
  p29:gp21
  d26

	d60

  p29:gp22
  d26

  del_p39 pl20:f2
  (p1 ph1+ph10)
  del_bird
  (center (p2 ph2+ph10) (p39:sp4 ph10):f2 )
  del_bird
  (p1 ph20+ph10)
  (p39:sp4 ph20+ph10):f2

  p29:gp22
  d26
	d60  

 lo to 4 times l11

  0.1u REC_UNBLK
  ;0.05u DWELL_RELEASE
  0.05u DWL_CLK_ON
  d62
  ;0.05u DWELL_HOLD
  0.05u DWL_CLK_OFF
  0.1u REC_BLK

  p29:gp23
  d26 ipp10
  (p2 ph1+ph10)
  p29:gp23
  d26

	d60

  p29:gp24
  d26

  del_p39 pl20:f2
  (p1 ph1+ph10)
  del_bird
  (center (p2 ph2+ph10) (p39:sp4 ph10):f2 )
  del_bird
  (p1 ph20+ph10)
  (p39:sp4 ph20+ph10):f2

  p29:gp24
  d26
	d60  

  0.1u REC_UNBLK
  ;0.05u DWELL_RELEASE
  0.05u DWL_CLK_ON
  d63
  ;0.05u DWELL_HOLD
  0.05u DWL_CLK_OFF
  0.1u REC_BLK

  rcyc=2

  50u BLKGRAMP

#   else       ; if not real-time homodecoupling

  20u BLKGRAMP 
  go=2 ph31 
#   endif

  1m mc #0 to 2 
#   ifdef CH2suppr
     F0(iu5 & ip31*2 & zd) ; difference spectroscopy CH2 suppression
#   endif
#   ifdef push_INT ; if interferogram homodecoupling
     F1QF(caldel(d30, +in30)) ; pure shift pseudo2d
     F2EA(calgrad(EA) & calph(ph14, +180) & calph(ph15, +180) & calclc(l1,+1), caldel(d0, +in0) & caldel(d10, +in10) & calph(ph3, +180) & calph(ph31, +180)) ; hsqc+2dj
#   else       ; if not interferogram homodecoupling
     F1EA(calgrad(EA) & calph(ph14, +180) & calph(ph15, +180) & calclc(l1,+1), caldel(d0, +in0) & caldel(d10, +in10) & calph(ph3, +180) & calph(ph31, +180)) ; hsqc+2dj
#   endif 

exit
50u BLKGRAMP
20u LOCKH_OFF

ph1=0 
ph2=1
ph20=2

#   ifdef SEL13C
ph3=0
ph8=0 1
#   else
ph3=0 2
ph8=0
#   endif

ph4={0}*16 {2}*16
ph25={0}*4 {1}*4 ; 180 in hsqc
ph9=0
ph14=2
ph15=1

ph5= 0          ; 180 1
ph11=0 ;sel 1H pulse 1
ph6= {0}*2 {1}*2 {0}*2 {1}*2 {2}*2 {3}*2 {2}*2 {3}*2  ; ASR
ph16=ph6+ph2  
ph17=ph6+ph20
ph12=0 ; sel 1H pulse 2
ph7= 0            ; 180 2

ph10 = 0 0 2 2 0 2 2 0 2 2 0 0 2 0 0 2 ; supercycle for real-time homodecoupling

ph29=0 ; presat

ph30=0
ph31=ph3 + ph4*2 + ph8*2 + ph5*2 - ph6*2 + ph7*2

;pl0 : f1 channel - 0W
;pl20 : f2 channel - 0W
;pl1 : f1 channel - power level for pulse (default)
;pl2 : f2 channel - power level for pulse (default)
;pl3 : f3 channel - power level for pulse (default)
;pl9 : f1 channel - power level for presaturation
;sp1: f2 channel - selective shaped pulse 180 degree refocusing
;spnam1: Selective 180 refocusing pulse shape name
;sp3: f2 channel - shaped pulse 180 degree
;sp4: f2 channel - shaped pulse (180degree Inversion)
;spnam4: Bip720,100,10.1
;sp7: f2 channel - shaped pulse (180degree refocussing)
;spnam7: Crp60comp.4
;sp11 : f1 channel - 1H 180 inversion selective pulse on spin S
;spnam11: shape name for 1H 180 inversion selective pulse on spin S
;sp12 : f1 channel - 1H 180 time reversed inversion selective pulse on spin S
;spnam12: shape name for 1H 180 time reversed inversion selective pulse on spin S
;sp23: f2 channel - time reversed shaped pulse 180 degree
;p1 : f1 channel -  90 degree high power pulse
;p2 : f1 channel - 180 degree high power pulse
;p3 : f2 channel -  90 degree high power pulse
;p4 : f2 channel - 180 degree high power pulse
;p14: f2 channel - 180 degree shaped pulse (sp3) for inversion
;p15: f2 channel - 180 degree shaped selective refocusing pulse
;p16: homospoil/gradient pulse
;p21: f3 channel -  90 degree high power pulse
;p22: f3 channel - 180 degree high power pulse
;p24: f2 channel - 180 degree shaped pulse (sp7) for refocussing
;     = 2msec for Crp60comp.4
;p28: f1 channel - trim pulse
;p39: f2 channel - 180 degree shaped pulse (sp4) for Inversion
;                      Bip720,100,10.1 (160us at 600.13 MHz)
;d0 : incremented delay 13C chemical shift
;d10 : incremented delay JHH
;d30 : incremented delay interferogram
;d1 : relaxation delay; 1-5 * T1
;d4 : 1/(4J)XH
;d11: delay for disk I/O                             [30 msec]
;d16: delay for homospoil/gradient recovery
;cnst2: = J(XH) used for INEPT/ST2PT
;cnst3: = J(XH) used for BIRD
;cnst5: = J(XH) for CH2 groups, for their suppression
;cnst6 : lower chemical shift edge for 1H inversion pulse in ppm
;cnst7 : upper chemical shift edge for 1H inversion pulse in ppm
;cnst28 : Bandwidth in ppm of 13C selective refocusing pulse
;cnst15 : upscale of JHH (if >1) or downscale of 13C Chem. Shift (if <1)
;cnst17: = -0.5 for Crp60comp.4
;in0: 1/(2 * SW(X)) = DW(X)
;ns: 1 * n
;ds: >= 16
;td1: number of experiments
;FnMODE: (F1 in 2D) echo-antiecho
;FnMODE: (F2 in pseudo3d) echo-antiecho
;FnMODE: (F2 in pseudo3d) QF
;cpd3: decoupling according to sequence defined by cpdprg3
;pcpd3: f3 channel - 90 degree pulse for decoupling sequence

;l2 : 0 for left-hand 13C satellite; 1 for right-hand satellite

;l1 : Switch for Pell-Keeler

;specific for interferogram homodecoupling
;l31 : number of time domain points per chunk (preferably power of 2)
;cnst0 : SWH(F1) = 1/Chunklength ; ideally 2 times multiplet width
;cnst4: number of drop points [typically 4]

;specific for real-time bird homodecoupling
;p29: gradient pulse length in ACQ [500u]
;d26: delay for gradient recovery in ACQ [500u]
;d60: optional extra delay for longer stab prior to chunks [0u]
;d62: duration of chunks [set by aq/l0]
;d63: duration of first and last half chunks
;l10: number of chunks to acquire [2*integer]

;for z-only gradients:
;gpz1: 80%
;gpz3: -2.97% = 17.13%-20.1%
;gpz4: 17.13%
;gpz5: 44%
;gpz6: 13.17% 
;gpz7: 5.25%
;gpz8: 7.25%
;gpz21: 17%
;gpz22: 31%
;gpz23: 19%
;gpz24: 33%

;use gradient files:   
;gpnam1: SMSQ10.100
;gpnam3: SMSQ10.100
;gpnam4: SMSQ10.100
;gpnam5: SMSQ10.100
;gpnam6: SMSQ10.100
;gpnam7: SMSQ10.100
;gpnam8: SMSQ10.100
;gpnam21: SMSQ10.50
;gpnam22: SMSQ10.50
;gpnam23: SMSQ10.50
;gpnam24: SMSQ10.50


